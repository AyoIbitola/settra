# Environment Configuration
# Copy this to .env and fill in real values. Never commit .env to source control.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/invoicing

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Bitnob ───────────────────────────────────────────────────────────────────
BITNOB_BASE_URL=https://sandboxapi.bitnob.co   # Change to https://api.bitnob.co for production
BITNOB_CLIENT_ID=your-bitnob-client-id
BITNOB_CLIENT_SECRET=your-bitnob-client-secret
BITNOB_WEBHOOK_SECRET=your-bitnob-webhook-secret

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key
EMAIL_FROM_ADDRESS=receipts@yourapp.com

# ─── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
ENVIRONMENT=development   # development | staging | production
